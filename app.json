{
  "expo": {
    "name": "softway-hvac",
    "slug": "softway-hvac",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "softwayhvac",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.adityaxpv.softwayhvac",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "android": {
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.adityaxpv.softwayhvac"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#1ABC9C"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0F1419",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-widgets",
        {
          "groupIdentifier": "group.com.adityaxpv.softwayhvac",
          "widgets": [
            {
              "name": "HVACStatusWidget",
              "displayName": "HVAC Status",
              "description": "Monitor the health of your HVAC units at a glance.",
              "supportedFamilies": ["systemSmall", "systemMedium", "systemLarge"],
              "android": null
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
